# AI Career Advisor — Environment Variables
# Copy file ini jadi ".env" dan isi dengan nilai kamu

# Supabase (dari Settings > API di dashboard Supabase)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Secret key untuk JWT (isi dengan string random yang panjang)
SECRET_KEY=ganti-dengan-string-random-panjang-minimal-32-karakter
